# AkibaHub environment variables example
# Copy this file to .env and fill real values

# Database (MariaDB)
DB_URL=jdbc:mariadb://localhost:3306/akibahub?useSSL=false&serverTimezone=UTC
DB_USERNAME=akibahub_user
DB_PASSWORD=your_strong_password
DB_DRIVER=org.mariadb.jdbc.Driver

# JWT
JWT_SECRET=your-256-bit-secret-key-change-me
JWT_EXPIRATION=86400000

# Optional: Google OAuth (if used)
# GOOGLE_CLIENT_ID=xxx
# GOOGLE_CLIENT_SECRET=xxx