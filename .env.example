# Copy to .env and replace placeholders. Never commit .env.

# Database
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=akibahub
MYSQL_PORT=3306
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me-db-password

# Backend
APP_PORT=8080
# Required: long random string (32+ chars). App fails to start without it.
JWT_SECRET=replace-with-a-long-random-alphanumeric-string

# Payments — demo mode for presentation (default). M-Pesa PIN is never
# collected or stored by Akiba Hub.
PAYMENTS_MODE=demo
APP_BASE_URL=http://localhost:8080
# Future live PayHero (leave empty in demo):
# PAYHERO_AUTH_TOKEN=
# PAYHERO_CHANNEL_ID=

# Optional: Spring profile on the backend container
# SPRING_PROFILES_ACTIVE=prod
