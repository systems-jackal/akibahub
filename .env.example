# ── Copy this file to .env and fill in all values ──────────────────────────
# Never commit .env to git

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_REPO=systems-jackal/akibahub

# ── Domain ──────────────────────────────────────────────────────────────────
DOMAIN_NAME=yourdomain.com
APP_BASE_URL=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# ── JWT ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=

# ── Internal service auth ────────────────────────────────────────────────────
# Generate: openssl rand -hex 16
INTERNAL_SERVICE_KEY=

# ── Google OAuth ─────────────────────────────────────────────────────────────
# From: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── PayHero ──────────────────────────────────────────────────────────────────
# From: app.payhero.co.ke → API Settings
PAYHERO_USERNAME=
PAYHERO_PASSWORD=
PAYHERO_CHANNEL_ID=

# ── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_USER=akiba
# Generate: openssl rand -hex 12
RABBITMQ_PASSWORD=

# ── MariaDB ──────────────────────────────────────────────────────────────────
# Generate all with: openssl rand -hex 16
MARIADB_ROOT_PASSWORD=
MARIADB_AUTH_PASSWORD=
MARIADB_SAVINGS_PASSWORD=
MARIADB_GROUPS_PASSWORD=
MARIADB_PAYMENTS_PASSWORD=
MARIADB_PROPOSALS_PASSWORD=
MARIADB_AUDIT_PASSWORD=
